# .env.example
# Copy this file to .env and fill in your values before running the app.

APP_NAME="MediScan AI"
APP_VERSION="1.0.0"
DEBUG=False

HOST=0.0.0.0
PORT=8000

SECRET_KEY=change-this-to-a-strong-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10

NLP_MODEL_NAME=dmis-lab/biobert-base-cased-v1.2
CV_MODEL_PATH=models/xray_model.pt
